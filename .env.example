# ============================================
# StoryForge Environment Variables
# ============================================
# Bu dosyayı .env olarak kopyala ve değerleri doldur:
#   cp .env.example .env
#
# LOCAL (geliştirme):  NODE_ENV=development
# VPS (production):    NODE_ENV=production
# ============================================

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL
POSTGRES_PASSWORD=your_strong_db_password_here

# Session (openssl rand -hex 32 ile üret)
SESSION_SECRET=your_super_secret_session_key_change_this

# JWT — Mobile auth (openssl rand -hex 32 ile üret)
JWT_SECRET=your_jwt_secret_change_this

# Server
PORT=3004
NODE_ENV=development
# Local'de 0.0.0.0, VPS'te bu satırı yazma (127.0.0.1 default)
BACKEND_BIND=0.0.0.0

# ============================================
# Firebase Push Notifications (Opsiyonel)
# ============================================
# Yöntem 1: Service Account JSON dosyası (önerilen)
# FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json
#
# Yöntem 2: Sadece Project ID (GCP ortamlarında Application Default Credentials ile)
# FIREBASE_PROJECT_ID=your-firebase-project-id
