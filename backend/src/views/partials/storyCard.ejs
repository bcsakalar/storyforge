<div class="col">
  <div class="card sf-story-card h-100">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start mb-2">
        <span class="badge sf-genre-badge"><%= story.genre %></span>
        <small class="text-muted"><%= story._count?.chapters || story.chapters?.length || 0 %> bölüm</small>
      </div>
      <h5 class="card-title"><%= story.title %></h5>
      <p class="card-text text-muted small">
        <i class="bi bi-clock"></i>
        <%= new Date(story.updatedAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
      </p>
    </div>
    <div class="card-footer bg-transparent border-0 d-flex gap-2">
      <a href="/story/<%= story.id %>" class="btn btn-outline-primary btn-sm flex-grow-1">
        <i class="bi bi-book"></i> Devam Et
      </a>
      <form action="/story/<%= story.id %>/delete" method="POST" class="d-inline"
            onsubmit="return confirm('Bu hikayeyi silmek istediğine emin misin?')">
        <button type="submit" class="btn btn-outline-danger btn-sm">
          <i class="bi bi-trash"></i>
        </button>
      </form>
    </div>
  </div>
</div>
