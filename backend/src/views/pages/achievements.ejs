<%- include('../layout', { body: `
<div style="max-width: 640px; margin: 0 auto;">
  <a href="/profile" class="sf-back">&larr; Profile Dön</a>

  <div class="sf-section-label">Koleksiyon</div>
  <h2>Başarımlar</h2>
  <p style="color: var(--text-muted); margin-bottom: 32px;">${unlockedKeys.length} / ${all.length} başarım kazanıldı</p>

  <div class="sf-achievements-grid">
    ${all.map(a => {
      const unlocked = unlockedKeys.includes(a.key);
      return '<div class="sf-achievement-card ' + (unlocked ? 'unlocked' : 'locked') + '"><div class="sf-achievement-icon">' + a.icon + '</div><strong>' + a.title + '</strong><small>' + a.description + '</small></div>';
    }).join('')}
  </div>
</div>
` }) %>
